# Render backend environment variables

NODE_ENV=production
PORT=3001

# Create a long random value
JWT_SECRET=change-this-to-a-long-random-secret

# Render PostgreSQL / Supabase Postgres connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
DATABASE_SSL=true

# Frontend URL after Vercel deploy
FRONTEND_URL=https://your-eqy-site.vercel.app
CORS_ORIGIN=https://your-eqy-site.vercel.app,http://localhost:5173

